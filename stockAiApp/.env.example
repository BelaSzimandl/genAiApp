# Azure Cosmos DB (NoSQL) — copy to .env and fill values
# Keys: Portal → cosmos-stockai-poc-ne2 → Keys, or:
#   az cosmosdb keys list -n cosmos-stockai-poc-ne2 -g rg-stockai-poc --type keys

COSMOS_ENDPOINT=https://cosmos-stockai-poc-ne2.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=LogInsights
COSMOS_CONTAINER=log_entries

# Embeddings: auto (fastembed) | hash | azure_openai
EMBEDDING_PROVIDER=auto

# Set to 1 after vector policy container is active (see infra/enable-vector-container.ps1)
COSMOS_VECTOR_NATIVE=0
