# Azure Cosmos DB (NoSQL) — copy to .env and fill values
# Keys: Portal → cosmos-stock-market-ai → Keys, or:
#   az cosmosdb keys list -n cosmos-stock-market-ai -g stock-market-ai-rg --type keys

COSMOS_ENDPOINT=https://cosmos-stock-market-ai.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=LogInsights
COSMOS_CONTAINER=log_entries

# Stock quotes (Foundry chatbot OpenAPI → this DB)
COSMOS_STOCK_DATABASE=StockMarket
COSMOS_STOCK_CONTAINER=quotes

# Embeddings: auto (fastembed) | hash | azure_openai
EMBEDDING_PROVIDER=auto

# Set to 1 after vector policy container is active (see infra/enable-vector-container.ps1)
COSMOS_VECTOR_NATIVE=0
