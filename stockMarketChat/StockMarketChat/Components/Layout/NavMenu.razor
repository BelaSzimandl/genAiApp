@using StockMarketChat.Client.Models
@using StockMarketChat.Services
@inject MarketDataService MarketData

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid brand-row">
        <a class="navbar-brand" href="">
            <span class="brand-mark">$</span>
            <span class="brand-text">MarketDesk</span>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Floor
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="chat">
                <span class="bi bi-chat-nav-menu" aria-hidden="true"></span> Chat
            </NavLink>
        </div>
    </nav>

    <div class="nav-footer px-3">
        <div class="mini-ticker">
            @if (_mini.Count == 0)
            {
                <div class="mini-line">Loading quotes…</div>
            }
            else
            {
                @foreach (var tick in _mini)
                {
                    <div class="mini-line @(tick.Up ? "up" : "down")">@tick.Symbol @tick.Change</div>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<TickerItemDto> _mini = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var ticker = await MarketData.GetTickerAsync();
            _mini = ticker.Items.Take(3).ToList();
        }
        catch
        {
            _mini = [];
        }
    }
}
